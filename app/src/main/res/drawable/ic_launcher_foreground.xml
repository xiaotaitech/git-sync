    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 68,58 m -5,0 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0" />

    <!-- Sync arrows (circular arc top-right, pointing clockwise) -->
