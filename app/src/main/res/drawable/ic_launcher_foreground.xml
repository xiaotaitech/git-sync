        android:fillColor="#FFFFFF"
        android:pathData="M 40,30 m -5,0 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0" />

    <!-- Bottom commit node (circle) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 40,78 m -5,0 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0" />

